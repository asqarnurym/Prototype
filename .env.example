# Fastest demo path without Google Cloud billing:
# Create a free Gemini API key in Google AI Studio and force edge-tts.
GEMINI_API_KEY=
# TTS_PROVIDER=edge

# Optional paid Gemini via Vertex AI.
# Set a Google Cloud project and service-account JSON (or other ADC credentials).
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
# DESCRIPTION_MODEL=gemini-2.5-flash

# Optional for Google Cloud TTS and Vertex AI ADC. Leave empty to use edge-tts for TTS.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional for Hugging Face corpus scripts.
HF_TOKEN=

# Optional reproducibility overrides.
# Uncomment these only if you want to force the same runtime on every machine.
# Leaving them commented preserves auto-detection.
# TTS_PROVIDER=edge
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_MODEL_SIZE=medium
# FFMPEG_PATH=ffmpeg
