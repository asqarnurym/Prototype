# ── Prototype — files that should NOT go into git ───────────

# Environment variables and API keys
.env
*.json.key
*service-account*.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/
.python-version

# Temporary files (audio, frames, TTS)
temp/*
!temp/.gitkeep

# Output artifacts (too large for git)
output/*
!output/.gitkeep

# Input videos (also large)
!input/.gitkeep
input/*.mp4
input/*.avi
input/*.mkv
input/**/*.mp4
input/**/*.avi
input/**/*.mkv
input/_uploads/*
!input/_uploads/.gitkeep
input/corpus_finevideo/*
!input/corpus_finevideo/.gitkeep
input/corpus_normalized/*
!input/corpus_normalized/.gitkeep
input/corpus_finevideo_metadata/*
!input/corpus_finevideo_metadata/.gitkeep

# Evaluation generated manifests and run outputs
evaluation/finevideo_selected_manifest_downloaded.csv
evaluation/finevideo_selected_manifest_normalized.csv
evaluation/corpus_manifest_seeded.csv
evaluation/corpus_manifest_normalized.csv
evaluation/run_*/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Linters / tools
.ruff_cache/
.playwright-cli/
.pytest_cache/
.playwright-mcp/
.uv-cache/
.sisyphus/

# Logs
logs/*
!logs/.gitkeep
uvicorn-qa.log

# Build
dist/
build/
backups/
academic_paper/Paper-output/
academic_paper/Edit.txt
academic_paper/*backup*.md
academic_paper/*.pdf
academic_paper/*.bbl
academic_paper/*.blg
academic_paper/*.log
selected_articles_conference/*.pdf
template/*.pdf
*.synctex.gz
*.aux
*.fdb_latexmk
*.fls
*.out
*.toc

# OS
Thumbs.db
.DS_Store

# Old local agent/audit residue
.omx/
